# =============================================================================
# Demo Gauntlet — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- API Keys ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...         # Required: primary LLM provider
OPENAI_API_KEY=sk-...                # Optional: fallback LLM provider
BRAVE_API_KEY=...                    # Optional: enables research agent web search

# --- Security ----------------------------------------------------------------
# Generate with: openssl rand -hex 32
# Startup logs a WARNING if this is left at the default value.
# In production (ENV_MODE=production) the app refuses to start with the default.
SECRET_KEY=your-secret-key-change-this

# Set to "production" to enable strict security validation at startup
ENV_MODE=development

# --- Demo Access -------------------------------------------------------------
# Optional: if set, the frontend auto-submits this code on page load (one-click demo).
# Must match BETA_INVITE_CODE on the backend. Leave blank to require manual entry.
VITE_DEMO_INVITE_CODE=

# Optional: server-side invite code gate. If set, /auth/login requires this code.
BETA_INVITE_CODE=

# --- CORS --------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Feature Flags -----------------------------------------------------------
ENABLE_RESEARCH=True
MAX_CHALLENGERS=3

# --- Database ----------------------------------------------------------------
# Default: local SQLite (no setup required for development)
DATABASE_URL=sqlite:///./data/app.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/demogauntlet

# --- Redis (required for background deck processing) -------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Blob Storage ------------------------------------------------------------
BLOB_STORAGE_TYPE=local
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_BUCKET_NAME=...

# --- Vector Store (ChromaDB) -------------------------------------------------
CHROMA_PERSISTENCE_PATH=./data/chroma_db
# CHROMA_SERVER_HOST=localhost
# CHROMA_SERVER_PORT=8000

# --- DSPy (optional) ---------------------------------------------------------
# Path to a compiled GauntletAgent JSON file for optimized answer generation.
# Run backend/dspy_optimization/optimize.py to produce this file.
# DSPY_PROGRAM_PATH=./data/gauntlet_agent.json
